  "keyFeatures": [
    "Type-safe API clients for YouVersion Platform",
    "React hooks for Bible data fetching and state management",
    "Pre-built UI components for Bible readers, verses, and navigation",
    "OAuth 2.0 PKCE authentication flow",
    "Multi-version Bible support with language filtering",
    "Customizable theming and styling"
  ],
